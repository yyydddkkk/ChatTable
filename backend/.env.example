APP_NAME=ChatTable
DEBUG=true
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
ENCRYPTION_KEY=replace-with-your-secret-key

DATABASE_URL=postgresql+psycopg://postgres:your_password@localhost:5432/chattable

REDIS_URL=redis://localhost:6379/0

CHAT_ENGINE=autogen

AGENT_RUNTIME_MODE=legacy

DISPATCHER_ENABLED=true
DISPATCHER_MODE=mixed
DISPATCHER_HARD_CAP=5
DISPATCHER_MAX_ROUNDS=2
DISPATCHER_PLANNER_MODEL=qwen-plus
DISPATCHER_PLANNER_API_KEY=
DISPATCHER_PLANNER_API_BASE=
DISPATCHER_PLANNER_TIMEOUT_MS=2500
DISPATCHER_PLANNER_RETRY=1
DISPATCHER_DEBUG_FEEDBACK=true

STREAM_CHUNK_BATCH_CHARS=24

AUTOGEN_CORE_LOG_LEVEL=WARNING
AUTOGEN_EVENTS_LOG_LEVEL=WARNING
LITELLM_LOG_LEVEL=WARNING
OPENAI_CLIENT_LOG_LEVEL=WARNING
