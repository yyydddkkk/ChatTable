APP_NAME=ChatTable
DEBUG=true
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
ENCRYPTION_KEY=replace-with-your-secret

# Database
# Local PostgreSQL example:
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/chattable

# Redis
REDIS_URL=redis://localhost:6379/0

# Chat engine mode: legacy | autogen
CHAT_ENGINE=legacy
AGENT_RUNTIME_MODE=legacy
