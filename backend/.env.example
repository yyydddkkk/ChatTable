APP_NAME=ChatTable
DEBUG=true
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
ENCRYPTION_KEY=replace-with-your-secret

# Database
# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://postgres:Ydk666666.@localhost:5432/chattable
DATABASE_URL=sqlite:///./chattable.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Chat engine mode: legacy | autogen
CHAT_ENGINE=legacy
